# Required because eslint-plugin-jsx-a11y@6.10.2 declares its eslint peer
# dependency as "^3 || ^4 || ... || ^9" and this project uses eslint 10.
# The plugin works fine with eslint 10; the peer range is just stale.
# Remove this once eslint-plugin-jsx-a11y publishes a release supporting eslint 10.
legacy-peer-deps=true
